# MongoDB Connection
# For local development, use: mongodb://localhost:27017/trading-journal
# For production, use your MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/trading-journal

# JWT Secret for token signing
# Generate a secure random string (min 32 characters):
# Windows: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# macOS/Linux: openssl rand -hex 32
JWT_SECRET=your-secure-random-secret-key-here-min-32-chars

# Server Port
PORT=5000

# Frontend URL (for CORS configuration)
# Local development: http://localhost:8080
# Production: adjust to your deployed frontend URL
FRONTEND_URL=http://localhost:8080

# Optional: Add additional configuration as needed
# NODE_ENV=development
